# Copia este archivo a ".env" en la raíz y en pipeline/ y llena tus propias
# credenciales gratuitas. Ninguna clave real debe comitearse nunca a git.
#
# Dónde conseguir cada una:
#   INEGI_TOKEN     -> https://www.inegi.org.mx/servicios/api_indicadores.html (registro instantáneo)
#   BANXICO_TOKEN   -> https://www.banxico.org.mx/SieAPIRest/service/v1/token (registro instantáneo)
#   FRED_API_KEY    -> https://fred.stlouisfed.org/docs/api/api_key.html (cuenta FRED, key inmediata)
#   BEA_API_KEY     -> https://apps.bea.gov/API/signup/ (registro con email, key por correo)
#   BLS_API_KEY     -> https://data.bls.gov/registrationEngine/ (registro, key v2)

INEGI_TOKEN=
BANXICO_TOKEN=
FRED_API_KEY=
BEA_API_KEY=
BLS_API_KEY=

# URL del Atlas Engine para cliente en modo conectado.
# Déjala vacía para usar archivos locales (static export).
# Ejemplo: NEXT_PUBLIC_ENGINE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_ENGINE_URL=
